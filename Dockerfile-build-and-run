FROM debian:trixie
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y cloc build-essential llvm clang lld flex yacc bison bc qemu-system-x86 expect
ADD minified minified
RUN cd minified && LLVM=1 make tinyconfig && sed -i 's/CONFIG_M686=y/# CONFIG_M686 is not set/' .config && sed -i 's/# CONFIG_M486 is not set/CONFIG_M486=y/' .config && yes "" | LLVM=1 make olddefconfig && LLVM=1 make -j`nproc`
ADD Makefile Makefile
# RUN apt-get install screen -y
ADD vmtest.tcl vmtest.tcl
RUN TERM=xterm make vm
